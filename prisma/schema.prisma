// Club10 Pool - Prisma Schema
// Database: PostgreSQL (Vercel Postgres / Neon / Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BatchStatus {
  FORMING
  FULL
  ACTIVE
  DISTRIBUTING
  CLOSED
}

enum MemberStatus {
  ACTIVE
  WITHDRAWAL_REQUESTED
  WITHDRAWN
}

enum TransactionType {
  DEPOSIT
  PROFIT_SHARE
  WITHDRAWAL
  FEE
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum BatchCategory {
  CENT
  STANDARD_1K
  STANDARD_5K
  STANDARD_10K
}

enum TradingPlatform {
  MT4
  MT5
}

enum ReferralPoolStatus {
  OPEN
  FULL
  ACTIVE
  CLOSED
}

enum ReferralMemberStatus {
  PENDING_PAYMENT
  PAID
  ACTIVE
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RebateStatus {
  PENDING
  CREDITED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  passwordHash  String
  role          String   @default("admin")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model Investor {
  id             String    @id @default(cuid())
  fullName       String
  email          String    @unique
  phone          String?
  nationalId     String?   @unique
  bankName       String?
  bankAccount    String?
  passwordHash   String?
  emailVerified  Boolean   @default(false)
  kycStatus      String    @default("NOT_SUBMITTED")
  walletAddress  String?
  nationality    String    @default("Nigeria")
  dateOfBirth    String?
  twoFaEnabled   Boolean   @default(false)
  twoFaSecret    String?
  twoFaMethod    String    @default("TOTP")
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  memberships           BatchMember[]
  transactions          Transaction[]
  referralPoolsCreated  ReferralPool[]
  referralMemberships   ReferralMember[]
  rebatesEarned         ReferralRebate[]
  payments              Payment[]

  @@map("investors")
}

model Batch {
  id                    String          @id @default(cuid())
  batchCode             String          @unique
  name                  String
  description           String?
  status                BatchStatus     @default(FORMING)
  targetMembers         Int
  contributionPerMember Decimal
  targetCapital         Decimal
  tradingAccountId      String?
  brokerName            String?
  startDate             DateTime?
  endDate               DateTime?
  actualEndDate         DateTime?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  category              BatchCategory?
  minContribution       Decimal?        @db.Decimal(18,2)
  maxContribution       Decimal?        @db.Decimal(18,2)
  currentAmount         Decimal         @default(0) @db.Decimal(18,2)
  targetAmount          Decimal?        @db.Decimal(18,2)
  tradingPlatform       TradingPlatform?
  investorPassword      String?
  tradingServer         String?
  referralPoolId        String?         @unique
  referralPool          ReferralPool?   @relation(fields: [referralPoolId], references: [id])
  payments              Payment[]

  members               BatchMember[]
  monthlyReports        MonthlyReport[]
  distributions         ProfitDistribution[]

  @@map("batches")
}

model BatchMember {
  id                      String       @id @default(cuid())
  batchId                 String
  investorId              String
  status                  MemberStatus @default(ACTIVE)
  capitalAmount           Decimal
  sharePercent            Decimal?
  joinedAt                DateTime     @default(now())
  withdrawalRequestedAt   DateTime?
  withdrawnAt             DateTime?

  batch        Batch       @relation(fields: [batchId], references: [id])
  investor     Investor    @relation(fields: [investorId], references: [id])
  transactions Transaction[]
  profitShares ProfitShare[]

  @@unique([batchId, investorId])
  @@map("batch_members")
}

model Transaction {
  id            String            @id @default(cuid())
  investorId    String
  batchMemberId String?
  type          TransactionType
  status        TransactionStatus @default(PENDING)
  amount        Decimal
  reference     String?
  notes         String?
  processedAt   DateTime?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  investor    Investor     @relation(fields: [investorId], references: [id])
  batchMember BatchMember? @relation(fields: [batchMemberId], references: [id])

  @@map("transactions")
}

model MonthlyReport {
  id              String   @id @default(cuid())
  batchId         String
  reportMonth     DateTime
  openingBalance  Decimal
  closingBalance  Decimal
  grossProfit     Decimal
  platformFeeRate Decimal  @default(0)
  platformFee     Decimal  @default(0)
  netProfit       Decimal
  notes           String?
  createdAt       DateTime @default(now())

  batch        Batch               @relation(fields: [batchId], references: [id])
  distribution ProfitDistribution?

  @@unique([batchId, reportMonth])
  @@map("monthly_reports")
}

model ProfitDistribution {
  id            String   @id @default(cuid())
  batchId       String
  reportId      String   @unique
  totalProfit   Decimal
  distributedAt DateTime @default(now())
  notes         String?

  batch   Batch         @relation(fields: [batchId], references: [id])
  report  MonthlyReport @relation(fields: [reportId], references: [id])
  shares  ProfitShare[]

  @@map("profit_distributions")
}

model ProfitShare {
  id             String  @id @default(cuid())
  distributionId String
  batchMemberId  String
  capitalAmount  Decimal
  sharePercent   Decimal?
  profitAmount   Decimal
  transactionRef String?

  distribution ProfitDistribution @relation(fields: [distributionId], references: [id])
  batchMember  BatchMember        @relation(fields: [batchMemberId], references: [id])

  @@map("profit_shares")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorEmail  String
  action      String
  entityType  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model SecurityCode {
  id         String    @id @default(cuid())
  investorId String
  purpose    String    // WITHDRAWAL | SETTINGS | LOGIN_2FA
  code       String
  expiresAt  DateTime
  usedAt     DateTime?
  createdAt  DateTime  @default(now())

  @@map("security_codes")
}

model PayoutRequest {
  id            String    @id @default(cuid())
  investorId    String
  batchCode     String
  amount        Decimal   @db.Decimal(18,2)
  walletAddress String
  status        String    @default("PENDING") // PENDING | CONFIRMED | CANCELLED
  paymentDone   Boolean   @default(false)
  paidAt        DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@map("payout_requests")
}

model ReferralPool {
  id            String             @id @default(cuid())
  creatorId     String
  creator       Investor           @relation(fields: [creatorId], references: [id])
  category      BatchCategory
  referralCode  String             @unique
  status        ReferralPoolStatus @default(OPEN)
  currentAmount Decimal            @default(0) @db.Decimal(18, 2)
  targetAmount  Decimal            @db.Decimal(18, 2)
  members       ReferralMember[]
  rebates       ReferralRebate[]
  batch         Batch?
  batchId       String?            @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  @@unique([creatorId, category], name: "one_active_pool_per_category")
}

model ReferralMember {
  id             String               @id @default(cuid())
  referralPoolId String
  referralPool   ReferralPool         @relation(fields: [referralPoolId], references: [id])
  investorId     String
  investor       Investor             @relation(fields: [investorId], references: [id])
  contribution   Decimal              @db.Decimal(18, 2)
  status         ReferralMemberStatus @default(PENDING_PAYMENT)
  joinedAt       DateTime             @default(now())
  paidAt         DateTime?
  payment        Payment?

  @@unique([referralPoolId, investorId])
}

model ReferralRebate {
  id             String       @id @default(cuid())
  referralPoolId String
  referralPool   ReferralPool @relation(fields: [referralPoolId], references: [id])
  creatorId      String
  creator        Investor     @relation(fields: [creatorId], references: [id])
  month          DateTime
  totalRebate    Decimal      @db.Decimal(18, 2)
  creatorBonus   Decimal      @db.Decimal(18, 2)
  adminNotes     String?
  status         RebateStatus @default(PENDING)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([referralPoolId, month])
}

model Payment {
  id               String          @id @default(cuid())
  investorId       String
  investor         Investor        @relation(fields: [investorId], references: [id])
  batchId          String?
  batch            Batch?          @relation(fields: [batchId], references: [id])
  referralMemberId String?         @unique
  referralMember   ReferralMember? @relation(fields: [referralMemberId], references: [id])
  amountUSD        Decimal         @db.Decimal(18, 2)
  amountNGN        Decimal         @db.Decimal(18, 2)
  exchangeRate     Decimal         @db.Decimal(18, 6)
  flwTxRef         String          @unique
  flwTxId          String?
  status           PaymentStatus   @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}
