// Club10 Pool - Prisma Schema
// Database: PostgreSQL (Vercel Postgres / Neon / Supabase)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────

enum BatchStatus {
  FORMING      // Accepting new members
  FULL
  ACTIVE       // Trading in progress
  DISTRIBUTING // End-of-month profit distribution
  CLOSED       // Batch completed / all payouts done
}

enum MemberStatus {
  ACTIVE
  WITHDRAWAL_REQUESTED // Requested to pull out at end of month
  WITHDRAWN
}

enum TransactionType {
  DEPOSIT          // Initial capital contribution
  PROFIT_SHARE     // End-of-month profit distribution
  WITHDRAWAL       // Capital withdrawal
  FEE              // Platform/management fee (optional)
}

enum TransactionStatus {
  PENDING
  CONFIRMED
  FAILED
}

enum BatchCategory {
  CENT         // $100  pool | contrib $10–$50
  STANDARD_1K  // $1,000 pool | contrib $100–$500
  STANDARD_5K  // $5,000 pool | contrib $1,000–$2,500
  STANDARD_10K // $10,000 pool | contrib $2,500–$5,000
}

enum TradingPlatform {
  MT4
  MT5
}

enum ReferralPoolStatus {
  OPEN    // accepting members / payments
  FULL    // target amount reached, awaiting admin activation
  ACTIVE  // admin activated — linked to a real Batch
  CLOSED
}

enum ReferralMemberStatus {
  PENDING_PAYMENT // joined pool, not yet paid
  PAID            // payment confirmed by Flutterwave webhook
  ACTIVE          // moved into the activated Batch
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RebateStatus {
  PENDING
  CREDITED
}

// ─────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String
  phone         String?
  passwordHash  String
  role          String   @default("admin") // admin | viewer
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model Investor {
  id            String   @id @default(cuid())
  fullName      String
  email         String   @unique
  phone         String?
  nationalId    String?  @unique
  bankName      String?
  bankAccount   String?
  passwordHash  String?  // nullable so existing investors aren't broken
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  memberships   BatchMember[]
  transactions  Transaction[]

  referralPoolsCreated  ReferralPool[]
  referralMemberships   ReferralMember[]
  rebatesEarned         ReferralRebate[]
  payments              Payment[]

  @@map("investors")
}

model Batch {
  id              String      @id @default(cuid())
  batchCode       String      @unique   // e.g. "BATCH-A", "BATCH-B", "BATCH-2024-01"
  name            String                // Human-readable name
  description     String?
  status          BatchStatus @default(FORMING)

  targetMembers   Int                   // e.g. 10
  contributionPerMember Decimal        // e.g. 100.00
  targetCapital   Decimal              // targetMembers × contributionPerMember

  tradingAccountId String?             // External trading account reference
  brokerName       String?

  startDate       DateTime?            // When trading begins
  endDate         DateTime?            // Planned end / distribution date
  actualEndDate   DateTime?

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  members         BatchMember[]
  monthlyReports  MonthlyReport[]
  distributions   ProfitDistribution[]

  category          BatchCategory?
  minContribution   Decimal?        @db.Decimal(18,2)
  maxContribution   Decimal?        @db.Decimal(18,2)
  currentAmount     Decimal         @default(0) @db.Decimal(18,2)
  targetAmount      Decimal?        @db.Decimal(18,2)
  tradingPlatform   TradingPlatform?
  investorPassword  String?
  tradingServer     String?
  referralPoolId    String?         @unique
  referralPool      ReferralPool?   @relation(fields: [referralPoolId], references: [id])
  payments          Payment[]

  @@map("batches")
}

model BatchMember {
  id              String       @id @default(cuid())
  batchId         String
  investorId      String
  status          MemberStatus @default(ACTIVE)
  capitalAmount   Decimal      // Actual amount deposited
  sharePercent    Decimal      // capitalAmount / totalCapital × 100 (computed at distribution)

  joinedAt        DateTime @default(now())
  withdrawalRequestedAt DateTime?
  withdrawnAt     DateTime?

  batch           Batch    @relation(fields: [batchId], references: [id])
  investor        Investor @relation(fields: [investorId], references: [id])
  transactions    Transaction[]
  profitShares    ProfitShare[]

  @@unique([batchId, investorId])
  @@map("batch_members")
}

model Transaction {
  id              String            @id @default(cuid())
  investorId      String
  batchMemberId   String?
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  amount          Decimal
  reference       String?           // External payment reference
  notes           String?
  processedAt     DateTime?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  investor        Investor     @relation(fields: [investorId], references: [id])
  batchMember     BatchMember? @relation(fields: [batchMemberId], references: [id])

  @@map("transactions")
}

model MonthlyReport {
  id              String   @id @default(cuid())
  batchId         String
  reportMonth     DateTime // First day of the month
  openingBalance  Decimal
  closingBalance  Decimal
  grossProfit     Decimal  // closingBalance - openingBalance
  platformFeeRate Decimal  @default(0)   // e.g. 0.10 = 10%
  platformFee     Decimal  @default(0)
  netProfit       Decimal  // grossProfit - platformFee
  notes           String?
  createdAt       DateTime @default(now())

  batch           Batch    @relation(fields: [batchId], references: [id])
  distribution    ProfitDistribution?

  @@unique([batchId, reportMonth])
  @@map("monthly_reports")
}

model ProfitDistribution {
  id              String   @id @default(cuid())
  batchId         String
  reportId        String   @unique
  totalProfit     Decimal
  distributedAt   DateTime @default(now())
  notes           String?

  batch           Batch         @relation(fields: [batchId], references: [id])
  report          MonthlyReport @relation(fields: [reportId], references: [id])
  shares          ProfitShare[]

  @@map("profit_distributions")
}

model ProfitShare {
  id               String  @id @default(cuid())
  distributionId   String
  batchMemberId    String
  capitalAmount    Decimal
  sharePercent     Decimal
  profitAmount     Decimal // Amount this member receives
  transactionRef   String?

  distribution     ProfitDistribution @relation(fields: [distributionId], references: [id])
  batchMember      BatchMember        @relation(fields: [batchMemberId], references: [id])

  @@map("profit_shares")
}

model AuditLog {
  id          String   @id @default(cuid())
  actorId     String?
  actorEmail  String
  action      String
  entityType  String?
  metadata    Json?
  createdAt   DateTime @default(now())

  @@map("audit_logs")
}

model ReferralPool {
  id            String             @id @default(cuid())
  creatorId     String
  creator       Investor           @relation(fields: [creatorId], references: [id])
  category      BatchCategory
  referralCode  String             @unique
  status        ReferralPoolStatus @default(OPEN)
  currentAmount Decimal            @default(0) @db.Decimal(18, 2)
  targetAmount  Decimal            @db.Decimal(18, 2)
  members       ReferralMember[]
  rebates       ReferralRebate[]
  batch         Batch?             
  batchId       String?            @unique
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt

  // One active pool per category per creator (until closed/activated)
  @@unique([creatorId, category], name: "one_active_pool_per_category")
}

model ReferralMember {
  id             String               @id @default(cuid())
  referralPoolId String
  referralPool   ReferralPool         @relation(fields: [referralPoolId], references: [id])
  investorId     String
  investor       Investor             @relation(fields: [investorId], references: [id])
  contribution   Decimal              @db.Decimal(18, 2)
  status         ReferralMemberStatus @default(PENDING_PAYMENT)
  joinedAt       DateTime             @default(now())
  paidAt         DateTime?
  payment        Payment?

  @@unique([referralPoolId, investorId])
}

model ReferralRebate {
  id             String         @id @default(cuid())
  referralPoolId String
  referralPool   ReferralPool   @relation(fields: [referralPoolId], references: [id])
  creatorId      String
  creator        Investor       @relation(fields: [creatorId], references: [id])
  month          DateTime       // The month this rebate covers (first day of month)
  totalRebate    Decimal        @db.Decimal(18, 2) // Total rebate entered by admin
  creatorBonus   Decimal        @db.Decimal(18, 2) // 10% of totalRebate
  adminNotes     String?
  status         RebateStatus   @default(PENDING)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([referralPoolId, month])
}

model Payment {
  id               String          @id @default(cuid())
  investorId       String
  investor         Investor        @relation(fields: [investorId], references: [id])
  // For direct batch joins (non-referral)
  batchId          String?
  batch            Batch?          @relation(fields: [batchId], references: [id])
  // For referral pool joins
  referralMemberId String?         @unique
  referralMember   ReferralMember? @relation(fields: [referralMemberId], references: [id])
  amountUSD        Decimal         @db.Decimal(18, 2)
  amountNGN        Decimal         @db.Decimal(18, 2)
  exchangeRate     Decimal         @db.Decimal(18, 6)
  flwTxRef         String          @unique // Flutterwave tx_ref (generated by us)
  flwTxId          String?         // Flutterwave id (from webhook)
  status           PaymentStatus   @default(PENDING)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
}
